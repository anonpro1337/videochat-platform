generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER
// ============================================================
model User {
  id            String   @id @default(cuid())
  firebaseUid   String   @unique
  email         String?  @unique
  phone         String?
  displayName   String
  username      String   @unique
  avatar        String?
  coverPhoto    String?
  bio           String?
  role          UserRole @default(USER)
  tier          AccountTier @default(FREE)
  status        UserStatus @default(OFFLINE)
  gender        Gender?
  dateOfBirth   DateTime?
  country       String?
  language      String?
  isVerified    Boolean  @default(false)
  isAnonymous   Boolean  @default(false)
  isOnboarded   Boolean  @default(false)
  coins         Int      @default(0)
  gems          Int      @default(0)
  xp            Int      @default(0)
  level         Int      @default(1)
  isBanned      Boolean  @default(false)
  banReason     String?
  banExpiresAt  DateTime?
  deviceId      String?
  lastActive    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  profile       UserProfile?
  settings      UserSettings?
  sessions      UserSession[]
  devices       UserDevice[]
  reports       Report[]          @relation("ReportedUser")
  reportsMade   Report[]          @relation("Reporter")

  friendshipsReceived Friendship[] @relation("Addressee")
  friendshipsSent     Friendship[] @relation("Requester")

  messages      Message[]
  matchesAsUser1 Match[] @relation("User1")
  matchesAsUser2 Match[] @relation("User2")

  callsAsCaller Call[] @relation("Caller")
  callsAsCallee Call[] @relation("Callee")

  notifications Notification[]
  payments      Payment[]
  subscriptions Subscription[]
  livestreams   Livestream[]
  transactions  Transaction[]
  moderationLogs ModerationLog[]

  @@index([email])
  @@index([username])
  @@index([firebaseUid])
  @@index([country])
  @@index([status])
  @@index([role])
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  interests         String[]
  languages         String[]
  photos            String[]
  videos            String[]
  bio               String   @default("")
  occupation        String?
  education         String?
  height            Int?
  relationshipStatus String?
  socialLinks       Json     @default("{}")
  vibeTags          String[]
  isLive            Boolean  @default(false)
  liveStreamId      String?
  followerCount     Int      @default(0)
  followingCount    Int      @default(0)
  friendCount       Int      @default(0)
  faceVerifiedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  showOnlineStatus  Boolean @default(true)
  showLocation      Boolean @default(false)
  showAge           Boolean @default(true)
  allowFriendRequests Boolean @default(true)
  allowMessages     Boolean @default(true)
  notificationSounds Boolean @default(true)
  darkMode          Boolean @default(true)
  language          String  @default("en")
  autoTranslate     Boolean @default(false)
  blurNudity        Boolean @default(true)
  saveChatHistory   Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id            String   @id @default(cuid())
  userId        String
  refreshToken  String   @unique
  deviceInfo    String?
  ipAddress     String?
  userAgent     String?
  isRevoked     Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String
  platform  String?
  pushToken String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

// ============================================================
// FRIENDSHIP
// ============================================================
model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

// ============================================================
// MATCH
// ============================================================
model Match {
  id        String      @id @default(cuid())
  user1Id   String
  user2Id   String
  type      MatchType
  status    MatchStatus @default(PENDING)
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  duration  Int         @default(0)
  isSkipped Boolean     @default(false)
  skippedBy String?
  reason    String?
  createdAt DateTime    @default(now())

  user1 User @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)

  messages Message[]

  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// MESSAGE
// ============================================================
model Message {
  id          String      @id @default(cuid())
  matchId     String
  senderId    String
  type        MessageType @default(TEXT)
  content     String
  translation String?
  metadata    Json        @default("{}")
  isDeleted   Boolean     @default(false)
  moderated   Boolean     @default(false)
  isSafe      Boolean     @default(true)
  createdAt   DateTime    @default(now())

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================================
// CALL
// ============================================================
model Call {
  id          String     @id @default(cuid())
  callerId    String
  calleeId    String
  type        CallType   @default(VIDEO)
  status      CallStatus @default(RINGING)
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int        @default(0)
  isPrivate   Boolean    @default(false)
  roomId      String?
  agoraChannel String?
  createdAt   DateTime   @default(now())

  caller User @relation("Caller", fields: [callerId], references: [id], onDelete: Cascade)
  callee User @relation("Callee", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([callerId])
  @@index([calleeId])
  @@index([status])
}

// ============================================================
// NOTIFICATION
// ============================================================
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================
// PAYMENT
// ============================================================
model Payment {
  id               String        @id @default(cuid())
  userId           String
  provider         PaymentProvider
  providerPaymentId String?
  type             TransactionType
  amount           Float
  currency         String         @default("USD")
  status           PaymentStatus  @default(PENDING)
  coins            Int?
  subscriptionId   String?
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Subscription {
  id            String        @id @default(cuid())
  userId        String        @unique
  provider      PaymentProvider
  providerSubId String?
  tier          AccountTier
  status        SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean        @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cancelledAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([tier])
}

model CoinPackage {
  id         String  @id @default(cuid())
  name       String
  coins      Int
  bonusCoins Int     @default(0)
  price      Float
  currency   String  @default("USD")
  isPopular  Boolean @default(false)
  isBestValue Boolean @default(false)
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
}

model Transaction {
  id        String  @id @default(cuid())
  userId    String
  type      String
  amount    Int
  balance   Int
  reference String?
  metadata  Json    @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// LIVESTREAM
// ============================================================
model Livestream {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  thumbnail   String?
  status      StreamStatus  @default(IDLE)
  viewerCount Int           @default(0)
  giftCount   Int           @default(0)
  totalGems   Int           @default(0)
  isAdult     Boolean       @default(false)
  category    String?
  tags        String[]
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
}

model Gift {
  id        String   @id @default(cuid())
  name      String
  emoji     String
  gems      Int
  price     Float
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model LivestreamGift {
  id          String   @id @default(cuid())
  livestreamId String
  senderId    String
  giftId      String
  quantity    Int      @default(1)
  totalGems   Int
  createdAt   DateTime @default(now())

  @@index([livestreamId])
}

// ============================================================
// REPORT / MODERATION
// ============================================================
model Report {
  id             String         @id @default(cuid())
  reporterId     String
  reportedUserId String
  matchId        String?
  messageId      String?
  reason         ReportReason
  description    String?
  evidence       String[]
  aiFlags        Json?
  status         ReportStatus   @default(PENDING)
  action         ModerationAction?
  reviewedById   String?
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

model ModerationLog {
  id          String           @id @default(cuid())
  userId      String
  action      ModerationAction
  reason      String
  duration    Int?
  modId       String
  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model ReportedMessage {
  id         String   @id @default(cuid())
  messageId  String
  reportedBy String
  reason     String
  aiScore    Float?
  isActioned Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ============================================================
// ENUMS
// ============================================================
enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum AccountTier {
  FREE
  PREMIUM
  VIP
}

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
  BUSY
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum MatchType {
  VIDEO
  TEXT
  VOICE
}

enum MatchStatus {
  PENDING
  ACTIVE
  ENDED
  SKIPPED
  REPORTED
}

enum MessageType {
  TEXT
  IMAGE
  GIF
  SYSTEM
  REACTION
  GIFT
}

enum CallType {
  VIDEO
  VOICE
}

enum CallStatus {
  RINGING
  CONNECTING
  CONNECTED
  ENDED
  MISSED
  REJECTED
}

enum NotificationType {
  MATCH
  MESSAGE
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FOLLOW
  LIKE
  GIFT
  STREAM_START
  MENTION
  SYSTEM
  MODERATION
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  GIFT
  REWARD
  SUBSCRIPTION
  WITHDRAWAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
}

enum ReportReason {
  NUDITY
  HARASSMENT
  SPAM
  UNDERAGE
  VIOLENCE
  HATE_SPEECH
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ModerationAction {
  WARN
  MUTE
  BAN
  DISMISS
}
