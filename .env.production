# App
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Database - Supabase Postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Redis - Upstash (set after creating)
REDIS_URL=
REDIS_PASSWORD=

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=[generate-new]
JWT_REFRESH_SECRET=[generate-new]
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# Agora
AGORA_APP_ID=[register-on-agora.io]
AGORA_APP_CERTIFICATE=[get-from-console]

# OpenAI
OPENAI_API_KEY=sk-[get-from-openai-api]

# Stripe
STRIPE_SECRET_KEY=sk_live_[get-from-stripe]
STRIPE_WEBHOOK_SECRET=whsec_[get-from-webhooks]

# Razorpay
RAZORPAY_KEY_ID=[get-from-dashboard]
RAZORPAY_KEY_SECRET=[get-from-dashboard]

# AWS S3
AWS_ACCESS_KEY_ID=[create-iam-user]
AWS_SECRET_ACCESS_KEY=[create-iam-user]
AWS_REGION=us-east-1
AWS_S3_BUCKET=videochat-prod

# URLs
WEB_APP_URL=https://videochat-web.vercel.app
API_URL=https://videochat-api.onrender.com
SOCKET_URL=https://videochat-api.onrender.com
SOCKET_CORS_ORIGIN=https://videochat-web.vercel.app
NEXT_PUBLIC_API_URL=https://videochat-api.onrender.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://videochat-api.onrender.com

# PostHog (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# FingerprintJS
FINGERPRINTJS_API_KEY=[get-from-fingerprintjs]

# reCAPTCHA
RECAPTCHA_SECRET_KEY=[get-from-google]

# Sentry (optional)
SENTRY_DSN=

# Next.js Public
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
NEXT_PUBLIC_AGORA_APP_ID=[placeholder]
NEXT_PUBLIC_STRIPE_KEY=[placeholder]
NEXT_PUBLIC_RAZORPAY_KEY=[placeholder]
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_FINGERPRINT_KEY=[placeholder]
NEXT_PUBLIC_RECAPTCHA_KEY=[placeholder]
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
