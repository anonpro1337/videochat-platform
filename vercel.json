{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "nodeVersion": "20.x",
  "framework": "monorepo",
  "buildCommand": "pnpm build",
  "outputDirectory": "apps/web/.next",
  "experimentalServices": {
    "web": {
      "framework": "nextjs",
      "entrypoint": "apps/web",
      "routePrefix": "/"
    },
    "admin": {
      "framework": "nextjs",
      "entrypoint": "apps/admin",
      "routePrefix": "/admin"
    }
  }
}
