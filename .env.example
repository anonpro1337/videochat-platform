# Environment Variables
# Copy this to .env and fill in your values

# App
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Supabase (replaces Firebase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agora (WebRTC)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# PostHog
POSTHOG_API_KEY=phc_your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# FingerprintJS
FINGERPRINTJS_API_KEY=your-fingerprint-key

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# Socket
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PORT=4001

# URLs
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
SOCKET_URL=http://localhost:4001

# Hive Moderation
HIVE_API_KEY=your-hive-key

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Sentry
SENTRY_DSN=

# Next.js Public
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_AGORA_APP_ID=
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_RAZORPAY_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_FINGERPRINT_KEY=
NEXT_PUBLIC_RECAPTCHA_KEY=
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
